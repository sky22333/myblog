<script>
  import NProgress from 'nprogress';
  
  // 配置 NProgress
  NProgress.configure({ 
    showSpinner: false,
    speed: 400,
    minimum: 0.1,
    trickleSpeed: 200,
    template: '<div class="bar" role="none"><div class="peg"></div></div>',
    barSelector: '.bar'
  });

  // 监听 Astro 页面导航事件
  document.addEventListener('astro:before-preparation', () => {
    NProgress.start();
  });

  document.addEventListener('astro:after-swap', () => {
    // 页面内容交换后，可以重置一些状态
  });

  document.addEventListener('astro:page-load', () => {
    NProgress.done();
  });
</script>

<style is:global>
  /* 自定义样式，覆盖默认的 */

  #nprogress {
    pointer-events: none;
  }

  #nprogress .bar {
    background: hsl(var(--primary));
    position: fixed;
    z-index: 1031;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
  }

  /* 阴影效果 */
  #nprogress .peg {
    display: block;
    position: absolute;
    right: 0px;
    width: 100px;
    height: 100%;
    box-shadow: 0 0 10px hsl(var(--primary)), 0 0 5px hsl(var(--primary));
    opacity: 1.0;
    transform: rotate(3deg) translate(0px, -4px);
  }

  /* 移除转圈 */
  #nprogress .spinner {
    display: none;
  }

  /* 调整层级，确保在最上层 */
  .nprogress-custom-parent {
    overflow: hidden;
    position: relative;
  }

  .nprogress-custom-parent #nprogress .spinner,
  .nprogress-custom-parent #nprogress .bar {
    position: absolute;
  }
</style>
