---
// 关于页面
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';

// 技能数据
const skills = [
  { name: "JavaScript", level: 90 },
  { name: "TypeScript", level: 85 },
  { name: "React", level: 88 },
  { name: "Next.js", level: 82 },
  { name: "Node.js", level: 80 },
  { name: "HTML/CSS", level: 95 },
  { name: "Tailwind CSS", level: 90 },
  { name: "Astro", level: 75 },
];

// 工具和技术
const technologies = [
  { name: "VS Code", icon: "vscode" },
  { name: "Git", icon: "git" },
  { name: "GitHub", icon: "github" },
  { name: "Docker", icon: "docker" },
  { name: "Figma", icon: "figma" },
  { name: "npm", icon: "npm" },
];

// 兴趣爱好
const hobbies = [
  "阅读", "写作", "摄影", "旅行", "编程", "学习新技术"
];
---

<BaseLayout title="关于">
  <Navbar slot="header" />
  
  <section class="py-12 md:py-16">
    <div class="container max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight mb-4">关于我</h1>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          热爱技术与分享的开发者，致力于探索前沿技术和解决方案
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="col-span-1">
          <div class="aspect-square rounded-lg bg-muted overflow-hidden relative">
            <img 
              src="https://t.alcy.cc/moe?postId=15" 
              alt="头像" 
              class="w-full h-full object-cover"
              onerror="this.onerror=null; this.src='https://via.placeholder.com/300?text=Avatar';"
            />
          </div>
        </div>
        
        <div class="col-span-2 space-y-4">
          <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
            <h2 class="text-2xl font-semibold mb-4">个人简介</h2>
            <div class="prose prose-lg dark:prose-invert">
              <p>
                作为一名热爱技术和分享的开发者，我致力于探索前沿技术和解决方案。
                通过这个博客，记录学习历程，分享技术见解，与志同道合的朋友交流。
              </p>
              <p>
                我相信持续学习和知识分享的力量，希望通过这个平台，为开发社区贡献自己的一份力量。
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 技能部分 -->
      <div class="mb-12">
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-6">专业技能</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {skills.map(skill => (
              <div class="space-y-2">
                <div class="flex justify-between">
                  <span class="font-medium">{skill.name}</span>
                  <span class="text-muted-foreground">{skill.level}%</span>
                </div>
                <div class="h-2 bg-muted rounded-full overflow-hidden">
                  <div 
                    class="h-full bg-primary rounded-full transition-all duration-1000 ease-out" 
                    style={`width: 0%; transition-delay: ${skills.indexOf(skill) * 100}ms;`}
                    data-width={`${skill.level}%`}
                  >
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <!-- 技术和工具 -->
      <div class="mb-12">
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-6">常用工具</h2>
          
          <div class="flex flex-wrap gap-4">
            {technologies.map(tech => (
              <div class="flex items-center p-3 border rounded-lg bg-background hover:border-primary transition-colors">
                <span class="font-medium">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <!-- 兴趣爱好 -->
      <div class="mb-12">
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-6">兴趣爱好</h2>
          
          <div class="flex flex-wrap gap-3">
            {hobbies.map(hobby => (
              <span class="px-3 py-1 bg-muted rounded-full text-sm">{hobby}</span>
            ))}
          </div>
        </div>
      </div>
      
      <!-- 博客技术栈 -->
      <div class="mb-12">
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-4">博客技术栈</h2>
          <div class="prose prose-lg dark:prose-invert">
            <p>
              本博客使用了以下技术和工具：
            </p>
            <ul>
              <li><a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> - 一个现代化的静态站点生成器</li>
              <li><a href="https://ui.shadcn.com" target="_blank" rel="noopener noreferrer">ShadcnUI</a> - 一套精美的UI组件库</li>
              <li><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer">Tailwind CSS</a> - 实用优先的CSS框架</li>
              <li><a href="https://www.typescriptlang.org" target="_blank" rel="noopener noreferrer">TypeScript</a> - 带类型的JavaScript超集</li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- 联系方式 -->
      <div class="mb-12">
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-4">联系方式</h2>
          <div class="prose prose-lg dark:prose-invert">
            <p>
              如果您有任何问题、建议或合作意向，欢迎通过以下方式联系我：
            </p>
            <ul>
              <li>邮箱：<a href="mailto:example@example.com">example@example.com</a></li>
              <li>GitHub：<a href="https://github.com/sky22333/myblog" target="_blank" rel="noopener noreferrer">github.com/yourusername</a></li>
              <li>微博：<a href="https://weibo.com/yourid" target="_blank" rel="noopener noreferrer">weibo.com/yourid</a></li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- 版权声明 -->
      <div>
        <div class="p-6 rounded-lg border bg-card transition-all hover:shadow-md">
          <h2 class="text-2xl font-semibold mb-4">版权声明</h2>
          <div class="prose prose-lg dark:prose-invert">
            <p>
              除特别注明外，本站所有文章均采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0 国际许可协议</a> 进行许可。
              转载请注明出处。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<script>
  // 进度条动画
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const progressBars = entry.target.querySelectorAll('[data-width]');
          progressBars.forEach(bar => {
            const width = bar.getAttribute('data-width');
            setTimeout(() => {
              (bar as HTMLElement).style.width = width || '0%';
            }, 100);
          });
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.2
    });
    
    const skillsSection = document.querySelector('.mb-12');
    if (skillsSection) {
      observer.observe(skillsSection);
    }
  });
</script>
