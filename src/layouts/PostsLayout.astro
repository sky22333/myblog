---
// 文章列表布局组件
// 用于显示文章列表页面
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import Pagination from '@/components/ui/pagination/Pagination';
import { formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description?: string;
  posts: any[];
  currentPage: number;
  totalPages: number;
  pageSize: number;
  basePath: string;
}

const { 
  title, 
  description = "文章列表", 
  posts, 
  currentPage, 
  totalPages, 
  pageSize,
  basePath
} = Astro.props;

// 处理分页跳转
const handlePageChange = (page: number) => {
  if (page === 1) {
    return basePath;
  }
  return `${basePath}/${page}`;
};
---

<BaseLayout title={title} description={description}>
  <Navbar slot="header" />
  
  <main class="container py-10">
    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">{title}</h1>
      {description && <p class="text-xl text-muted-foreground">{description}</p>}
    </header>
    
    <!-- 文章列表 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {posts.map((post) => (
        <a href={`/posts/${post.slug}`} class="group">
          <div class="relative overflow-hidden rounded-lg border bg-background transition-all hover:shadow-md">
            <!-- 文章封面图 -->
            {post.data.cover && (
              <div class="aspect-video overflow-hidden">
                <img 
                  src={post.data.cover} 
                  alt={post.data.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
            
            <!-- 文章内容 -->
            <div class="p-4">
              <!-- 置顶标识 -->
              {post.data.featured && (
                <div class="absolute top-4 right-4 bg-primary text-primary-foreground text-xs px-2 py-1 rounded-md">
                  置顶
                </div>
              )}
              
              <!-- 文章标题 -->
              <h3 class="text-lg font-semibold leading-tight line-clamp-2 group-hover:text-primary transition-colors">
                {post.data.title}
              </h3>
              
              <!-- 文章描述 -->
              <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
                {post.data.description}
              </p>
              
              <!-- 文章元数据 -->
              <div class="mt-4 flex items-center text-xs text-muted-foreground">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                
                {post.data.readingTime && (
                  <>
                    <span class="mx-2">•</span>
                    <span>{post.data.readingTime} 分钟阅读</span>
                  </>
                )}
              </div>
              
              <!-- 文章标签 -->
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="inline-flex items-center text-xs bg-muted px-2 py-1 rounded-md">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <!-- 分页 -->
    {totalPages > 1 && (
      <Pagination 
        currentPage={currentPage} 
        totalPages={totalPages} 
        onPageChange={(page) => handlePageChange(page)}
        client:load
      />
    )}
  </main>
  
  <Footer slot="footer" />
</BaseLayout>
