---
// 文章布局组件
// 用于显示单篇文章的详细内容
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import Breadcrumb from '@/components/ui/breadcrumb/Breadcrumb.astro';
import { formatDate } from '@/lib/utils';
import ImageLightbox from '@/components/ui/image-lightbox/ImageLightbox';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  cover?: string;
  author: string;
  tags?: string[];
  featured?: boolean;
  readingTime?: number;
  keywords?: string[];
  slug?: string;
}

const { 
  title, 
  description, 
  pubDate, 
  updatedDate, 
  cover, 
  author, 
  tags = [], 
  featured = false,
  readingTime,
  keywords = [],
  slug = ""
} = Astro.props;

// 构建文章数据对象，用于结构化数据
const postData = {
  data: {
    title,
    description,
    pubDate,
    updatedDate,
    cover,
    author,
    tags,
    featured,
    readingTime,
    slug
  }
};

// 构建面包屑导航项
const breadcrumbItems = [
  { name: '首页', url: '/' },
  { name: '文章', url: '/posts' },
  { name: title, url: Astro.url.pathname, current: true }
];
---

<BaseLayout 
  title={title} 
  description={description} 
  article={true} 
  image={cover} 
  keywords={keywords}
  post={postData}
>
  <Navbar slot="header" />
  
  <article class="container py-10 max-w-4xl mx-auto">
    <!-- 面包屑导航 -->
    <Breadcrumb items={breadcrumbItems} className="mb-6" />
    
    <!-- 文章头部 -->
    <header class="mb-8">
      {featured && (
        <div class="mb-4">
          <span class="inline-flex items-center px-4 py-1.5 text-sm md:text-base font-medium rounded-md bg-secondary text-secondary-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
              <path d="M19 8.71 13.29 3h-2.59L5 8.71l5.29 5.29L9 19h6l-1.29-5L19 8.71z"></path>
            </svg>
            精选文章
          </span>
        </div>
      )}
      
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">{title}</h1>
      
      <p class="text-xl text-muted-foreground mb-6">{description}</p>
      
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
        <time datetime={pubDate.toISOString()}>
          发布于 {formatDate(pubDate)}
        </time>
        
        {updatedDate && (
          <time datetime={updatedDate.toISOString()}>
            更新于 {formatDate(updatedDate)}
          </time>
        )}
        
        {readingTime && (
          <span>约 {readingTime} 分钟阅读</span>
        )}
        
        <span>作者: {author}</span>
      </div>
    </header>
    
    <!-- 文章封面图 -->
    {cover && (
      <div class="mb-8 rounded-lg overflow-hidden">
        <img 
          src={cover} 
          alt={title}
          width="1200"
          height="630"
          class="w-full h-auto object-cover will-change-transform transform-gpu"
          data-fallback="/images/default-post.jpg"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    
    <!-- 文章内容 -->
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>
    
    <!-- 文章标签 -->
    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t">
        <h2 class="text-lg font-semibold mb-4">标签</h2>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a 
              href={`/tags/${tag}`}
              class="inline-flex items-center px-3 py-1 rounded-md text-sm bg-muted hover:bg-muted/80 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
  
  <Footer slot="footer" />
  
  <!-- 图片灯箱组件 -->
  <ImageLightbox client:load />
</BaseLayout>

<script>
// 为文章内容中的图片添加优化属性
document.addEventListener('astro:page-load', () => {
  const articleImages = document.querySelectorAll('.prose img');
  articleImages.forEach(img => {
    if (img instanceof HTMLImageElement) {
      // 添加 GPU 加速
      img.classList.add('will-change-transform', 'transform-gpu');
      
      // 异步加载
      img.setAttribute('loading', 'lazy');
      img.setAttribute('decoding', 'async');
      
      // 确保有宽高比
      if (!img.hasAttribute('width') && !img.hasAttribute('height')) {
        img.setAttribute('width', '768');
        img.setAttribute('height', '432');
      }
    }
  });
  
  // 为代码块添加复制按钮
  setupCodeBlockCopyButtons();
});

// 设置代码块复制按钮
function setupCodeBlockCopyButtons() {
  const codeBlocks = document.querySelectorAll('pre:has(code)');
  
  codeBlocks.forEach(pre => {
    // 确保代码块有相对定位，以便正确放置复制按钮
    if (pre instanceof HTMLElement) {
      pre.style.position = 'relative';
    }
    
    const code = pre.querySelector('code');
    if (!code) return;
    
    const codeContent = code.textContent || '';
    
    // 创建复制按钮容器
    const buttonContainer = document.createElement('div');
    buttonContainer.className = 'code-copy-button-container';
    buttonContainer.style.position = 'absolute';
    buttonContainer.style.right = '0.5rem';
    buttonContainer.style.top = '0.5rem';
    
    // 创建复制按钮
    const copyButton = document.createElement('button');
    copyButton.className = 'code-copy-button rounded-md p-1.5 text-xs font-medium opacity-70 hover:opacity-100 transition-opacity bg-primary/10 text-primary hover:bg-primary/20 focus:outline-none focus:ring-2 focus:ring-primary/40';
    copyButton.setAttribute('aria-label', '复制代码');
    copyButton.setAttribute('title', '复制代码');
    
    // 复制图标 (使用内联SVG以避免依赖)
    copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
    
    // 添加点击复制功能
    copyButton.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(codeContent);
        
        // 复制成功后显示成功图标
        const originalInnerHTML = copyButton.innerHTML;
        copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        copyButton.setAttribute('aria-label', '已复制');
        copyButton.setAttribute('title', '已复制');
        
        // 2秒后恢复原始图标
        setTimeout(() => {
          copyButton.innerHTML = originalInnerHTML;
          copyButton.setAttribute('aria-label', '复制代码');
          copyButton.setAttribute('title', '复制代码');
        }, 2000);
      } catch (err) {
        console.error('复制失败:', err);
      }
    });
    
    // 将按钮添加到容器并添加到代码块
    buttonContainer.appendChild(copyButton);
    pre.appendChild(buttonContainer);
  });
}
</script>
